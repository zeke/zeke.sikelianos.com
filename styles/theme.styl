:root
  color-scheme light dark
  --color-main #000
  --color-heading #000
  --color-text #333
  --color-quote #666
  --color-quote-border #BBB
  --color-background #F5F5F5
  --color-card-background #FFF
  --color-code-background #EAEAEA
  --color-code-text #273142
  --color-code-border #D6DADD
  --color-inline-code-background #EEE
  --color-image-matte-background transparent
  --color-table-row-hover #FFF
  --color-subtle-border rgba(0,0,0,0.1)
  --color-thumbnail-placeholder-start #F5F5F5
  --color-thumbnail-placeholder-end #E8E8E8
  --color-shadow rgba(0,0,0,0.08)

@media (prefers-color-scheme: dark)
  :root
    --color-main #F2EEE7
    --color-heading #FFF8EE
    --color-text #D8D0C6
    --color-quote #B7AEA3
    --color-quote-border #5B554F
    --color-background #11100F
    --color-card-background #1B1917
    --color-code-background #1B1E24
    --color-code-text #E6EDF3
    --color-code-border #373D45
    --color-inline-code-background #1E1C1A
    --color-image-matte-background #F7F2EA
    --color-table-row-hover #1B1917
    --color-subtle-border rgba(255,255,255,0.12)
    --color-thumbnail-placeholder-start #23201D
    --color-thumbnail-placeholder-end #171514
    --color-shadow rgba(0,0,0,0.35)
