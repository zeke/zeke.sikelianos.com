color-main = var(--color-main)
color-heading = var(--color-heading)
color-text = var(--color-text)
color-quote = var(--color-quote)
color-quote-border = var(--color-quote-border)
color-background = var(--color-background)
color-code-background = var(--color-code-background)
color-code-text = var(--color-code-text)
color-code-border = var(--color-code-border)

color-twitter = #55ACEE
color-github = #000
color-npm = #CB3837
color-email = #CCC
color-rubygems = #E9573F
color-flickr = #FF1981
color-instagram = #004879

base-font-family = Georgia, serif

card-width = 320px
card-gutter-width = 40px
card-thumbnail-height = 240px
card-details-height = 100px
card-background-color = var(--color-card-background)
width-of-three-columns = card-width*3 + card-gutter-width*3
width-of-two-columns = card-width*2 + card-gutter-width*2
width-of-one-column = card-width*1 + card-gutter-width*1

text-column-width = 740px

mobile-width = 480px

base-font-size = 1.1rem
